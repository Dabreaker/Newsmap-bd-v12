{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 30,
        "memory": 512,
        "includeFiles": [
          "node_modules/sql.js/dist/**",
          "public/**",
          "credentials.json",
          "middleware/**",
          "db.js"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/server.js" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
